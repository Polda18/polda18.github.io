{
    "$schema": "http://json-schema.org/draft-07/schema",
    "$id": "https://github.com/Polda18/polda18.github.io/raw/master/json_schemas/discord_bots/locale.json",
    "$comment": "Locale schema",
    "contentMediaType": "application/json",
    "type": "object",
    "definitions": {
        "name": {
            "$id": "#locale_name",
            "$comment": "Locale language name complete with country designation",
            "type": "string",
            "examples": [
                "Čeština (Česká republika",
                "English (United States)",
                "English (United Kingdom)"
            ]
        },
        "author": {
            "$id": "#locale_author",
            "$comment": "Locale author (not really used in the bot code, used for identification.",
            "type": "string",
            "examples": [
                "CZghost",
                "NickFury"
            ]
        },
        "locale_strings": {
            "$id": "#locale_strings",
            "$comment": "Actual locales to translate from locale codes",
            "type": "object",
            "definitions": {},
            "properties": {}
        }
    },
    "properties": {
        "name": { "$ref": "#locale_name" },
        "author": { "$ref": "#locale_author" },
        "locale_strings": { "$ref": "#locale_strings" }
    }
}